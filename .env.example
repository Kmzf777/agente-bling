# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Bling OAuth (API v3)
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REDIRECT_URI=http://localhost:3000/api/bling/callback
# IDs (separados por vírgula) das situações consideradas "faturado" na sua conta Bling
BLING_SITUACAO_FATURADO_IDS=

# App
APP_PASSWORD=troque-esta-senha
SESSION_SECRET=gere-um-segredo-aleatorio-longo
PORT=3000

# CORS: origem permitida do frontend. "*" é seguro pois a auth é por token Bearer.
# Em produção dá para restringir, ex.: CORS_ORIGIN=https://agente-bling.vercel.app
CORS_ORIGIN=*

# --- Frontend (NÃO é lido pelo backend) ---
# No build do frontend na Vercel, defina VITE_API_BASE com a URL pública do backend (ngrok):
# VITE_API_BASE=https://SEU-SUBDOMINIO.ngrok-free.app
